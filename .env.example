# Copy to .env.local and fill in. Values here are read server-side only (not exposed to the client).

# Required for ETH + AZTEC prices: CoinMarketCap API key.
# Free "Basic" plan works for the /cryptocurrency/quotes/latest endpoint
# (https://coinmarketcap.com/api/). ~10k call credits/month, plenty for an
# hourly-cached dashboard.
COINMARKETCAP_API_KEY=

# Optional: CoinMarketCap numeric ID for the AZTEC token (preferred over symbol
# if "AZTEC" resolves ambiguously or isn't yet listed under that ticker).
# Find it on the CMC listing URL, e.g. coinmarketcap.com/currencies/<slug>/ - the
# numeric ID is exposed via /v1/cryptocurrency/map.
AZTEC_CMC_ID=

# Optional: override the CoinMarketCap symbol we query. Defaults to "AZTEC".
# Leave blank unless the token ships under a different ticker on CMC.
AZTEC_TOKEN_SYMBOL=

# Required for gas prices: Etherscan API key (https://etherscan.io/myapikey).
# - Free tier covers the current gas oracle.
# - The 30-day rolling average uses `dailyavggasprice` which requires the
#   Etherscan Standard plan or above. Without it we fall back to the current
#   gas price and surface a warning in the UI.
ETHERSCAN_API_KEY=

# Optional: Ethereum JSON-RPC URL for eth_blobBaseFee (no Etherscan endpoint
# exists for blob gas). Defaults to cloudflare-eth.com. Set to an authenticated
# provider (Alchemy, Infura, etc.) if you hit rate limits.
ETH_RPC_URL=
